{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "/assets/(.*)\\.js$",
      "dest": "/assets/$1.js",
      "headers": {
        "content-type": "application/javascript; charset=utf-8"
      }
    },
    {
      "src": "/assets/(.*)\\.css$",
      "dest": "/assets/$1.css",
      "headers": {
        "content-type": "text/css; charset=utf-8"
      }
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/.*",
      "dest": "/index.html"
    }
  ]
}
