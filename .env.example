# Copy to .env.local and fill the values for local development
# Supabase (required for auth to work)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Dev helper: skips email verification and auto-logins new users (only for local dev)
VITE_SKIP_EMAIL_VERIFICATION=true

# Stripe (Frontend)
VITE_STRIPE_PUBLIC_KEY=pk_test_...

# Stripe (Backend - Serverless Functions only - set in Vercel)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PREMIUM=price_...
STRIPE_PRICE_ID_PRO=price_...

# Supabase (Backend - for webhooks - set in Vercel)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Frontend URL (for Stripe redirects)
FRONTEND_URL=http://localhost:8080

# PropFirm Scraper
ENCRYPTION_KEY=your-32-char-encryption-key-here

# MetaAPI (for MT4/MT5)
METAAPI_TOKEN=your-metaapi-token

# SendGrid
SENDGRID_API_KEY=your-sendgrid-key
WELCOME_FROM_EMAIL=hello@cyclewise.com
